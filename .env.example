# --- HTTP API ---
HTTP_ADDR=:8080

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=prices
POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/prices?sslmode=disable

# --- Redis ---
REDIS_ADDR=redis:6379

# --- Kafka ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=prices.ticks

# --- Binance ---
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
SYMBOLS=BTCUSDT,ETHUSDT

# --- App ---
LATEST_TTL=60s
LOG_LEVEL=info
